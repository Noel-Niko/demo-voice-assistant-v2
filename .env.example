# =============================================================================
# Voice Assistant Demo - Environment Configuration
# =============================================================================
#
# IMPORTANT: This is a template file with placeholder values.
#
# Setup Instructions:
#   1. Copy this file: cp .env.example .env
#   2. Edit .env with your actual values
#   3. Run: cd backend && make run
#   4. .env is auto-loaded via python-dotenv
#
# SECURITY WARNING:
#   - NEVER commit .env to version control (it's in .gitignore)
#   - .env.example is safe to commit (contains no secrets)
#   - Environment variables override .env values (12-factor compliance)
#
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: OpenAI Configuration
# -----------------------------------------------------------------------------
# Your OpenAI API key for LLM features
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# -----------------------------------------------------------------------------
# OPTIONAL: MCP Server Configuration
# -----------------------------------------------------------------------------
# MCP server base URL for tool augmentation and listening mode
# Example: http://localhost:8080 or https://your-mcp-server.example.com
# If not set, MCP features will be disabled
#MCP_INGRESS_URL=http://localhost:8080

# Shared secret for signing JWT tokens to authenticate with MCP server
# Must match the secret configured on the MCP server
# If not set, MCP requests will be sent without authentication
#MCP_SECRET_KEY=your-jwt-signing-secret-here

# MCP discovery endpoint path or full URL
# Default: /tools/discovery
# Can be relative path (e.g., /custom/discover) or absolute URL (e.g., https://other-server.com/api/discover)
#MCP_DISCOVERY_ENDPOINT=/tools/discovery

# MCP request timeout in seconds
# Default: 90.0
#MCP_REQUEST_TIMEOUT=90.0

# JWT algorithm for MCP authentication
# Default: HS256
#MCP_SECRET_ALGORITHM=HS256

# MCP environment identifier
# Default: prod
#MCP_ENVIRONMENT=prod

# -----------------------------------------------------------------------------
# OPTIONAL: Database Configuration
# -----------------------------------------------------------------------------
# SQLite database file path
# Default: backend/transcripts.db (auto-configured)
#DATABASE_URL=sqlite+aiosqlite:///./transcripts.db

# -----------------------------------------------------------------------------
# OPTIONAL: Redis Configuration
# -----------------------------------------------------------------------------
# Redis URL for caching and pub/sub
# Default: None (uses in-memory implementations for local dev)
# Local testing: redis://localhost:6379/0 (requires docker-compose up redis)
# Production: redis://:password@redis-cluster:6379/0
#REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# OPTIONAL: Server Configuration
# -----------------------------------------------------------------------------
# Server host and port
# Defaults: 0.0.0.0:8765
#HOST=0.0.0.0
#PORT=8765

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO
#LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# OPTIONAL: OpenAI Model Configuration
# -----------------------------------------------------------------------------
# OpenAI model to use (can be changed via UI)
# Default: gpt-3.5-turbo
#OPENAI_MODEL=gpt-3.5-turbo

# Max tokens for completion
# Default: 500
#OPENAI_MAX_TOKENS=500

# Temperature for completion (0.0-2.0)
# Default: 0.0
#OPENAI_TEMPERATURE=0.0

# -----------------------------------------------------------------------------
# OPTIONAL: Business Logic Configuration
# -----------------------------------------------------------------------------
# Summary generation interval in seconds
# Default: 5
#SUMMARY_INTERVAL_SECONDS=5

# Transcript streaming rate (words per second)
# Default: 8.5
#TRANSCRIPT_WORDS_PER_SECOND=8.5

# Delay before first transcript message (seconds)
# Default: 1.0
#TRANSCRIPT_INITIAL_DELAY=1.0

# Delay between transcript lines (seconds)
# Default: 0.25
#TRANSCRIPT_INTER_LINE_DELAY=0.25

# Path to transcript data file
# Default: ../Option2_data_file_v2.txt
#TRANSCRIPT_FILE_PATH=../Option2_data_file_v2.txt

# -----------------------------------------------------------------------------
# OPTIONAL: Event Bus Configuration
# -----------------------------------------------------------------------------
# Event queue size for in-memory event bus
# Default: 1000
#EVENT_QUEUE_SIZE=1000

# -----------------------------------------------------------------------------
# OPTIONAL: Utterance Detection Configuration
# -----------------------------------------------------------------------------
# Timeout thresholds for adaptive utterance finalization (seconds)
# Based on confidence and completeness

# High-confidence complete utterances (questions, commands)
# Default: 1.0
#UTT_SHORT_TIMEOUT_S=1.0

# Medium-confidence complete statements
# Default: 2.0
#UTT_MEDIUM_TIMEOUT_S=2.0

# Low-confidence or incomplete phrases
# Default: 4.0
#UTT_LONG_TIMEOUT_S=4.0

# Force finalization hard cap
# Default: 5.0
#UTT_HARD_MAX_TIMEOUT_S=5.0

# Confidence thresholds
#UTT_CONFIDENCE_HIGH=0.85
#UTT_CONFIDENCE_GOOD=0.70

# Minimum word counts for complete utterances
#UTT_MIN_WORDS_COMPLETE=4
#UTT_MIN_WORDS_QUESTION=3
#UTT_MIN_WORDS_COMMAND=3

# -----------------------------------------------------------------------------
# OPTIONAL: Semantic Layer Configuration (spaCy)
# -----------------------------------------------------------------------------
# Disable semantic analysis (requires spaCy installation)
# Default: false
#UTT_DISABLE_SPACY_SEMANTIC=false

# Minimum confidence for semantic override
# Default: 0.85
#UTT_SEMANTIC_CONFIDENCE_THRESHOLD=0.85

# -----------------------------------------------------------------------------
# OPTIONAL: Listening Mode Configuration
# -----------------------------------------------------------------------------
# Enable listening mode feature (auto-triggers on specific phrases)
# Default: true
#LISTENING_MODE_ENABLED=true

# Use utterance-based detection (vs periodic polling)
# Default: true
#LISTENING_MODE_USE_UTTERANCES=true
